{
  "name": "taskpilot-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.49.4",
    "cors": "2.8.5",
    "express": "4.21.2",
    "express-rate-limit": "7.5.0",
    "helmet": "8.1.0",
    "openai": "4.85.4",
    "pino": "9.6.0",
    "pino-pretty": "13.0.0",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "5.0.1",
    "@types/node": "22.13.10",
    "@types/supertest": "6.0.2",
    "eslint": "9.22.0",
    "@eslint/js": "9.22.0",
    "typescript-eslint": "8.27.0",
    "prettier": "3.5.3",
    "supertest": "7.1.0",
    "tsx": "4.19.3",
    "typescript": "5.8.2",
    "vitest": "3.0.9"
  }
